generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//// customization tables ////

model user {
  sys_id			String		@id @default(uuid())
  full_name			String		 @db.VarChar(50)
  phone			String		@unique @db.VarChar(13)
  active			Boolean		
  password			String?		 @db.VarChar(100)
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  roles			userRole[]		@relation("reference_user_roles")
  ordersAsUser			order[]		@relation("reference_order_user_id")
  ordersAsSeller			order[]		@relation("reference_order_seller_id")
  ordersCreated			order[]		@relation("reference_order_user_created_by")
  ordersUpdated			order[]		@relation("reference_order_user_updated_by")
  usersCreated			user[]		@relation("reference_user_user_created_by")
  usersUpdated			user[]		@relation("reference_user_user_updated_by")
  userRolesCreated			userRole[]		@relation("reference_userRole_user_created_by")
  userRolesUpdated			userRole[]		@relation("reference_userRole_user_updated_by")
  attachmentsCreated			attachment[]		@relation("reference_attachment_user_created_by")
  attachmentsUpdated			attachment[]		@relation("reference_attachment_user_updated_by")
  attachmentDocumentsCreated			attachment_document[]		@relation("reference_attachmentDocument_user_created_by")
  attachmentDocumentsUpdated			attachment_document[]		@relation("reference_attachmentDocument_user_updated_by")
  choicesCreated			choice[]		@relation("reference_choice_user_created_by")
  choicesUpdated			choice[]		@relation("reference_choice_user_updated_by")
  NavigationsCreated			navigation_role[]		@relation("reference_nav_role_user_created_by")
  NavigationsUpdated			navigation_role[]		@relation("reference_nav_role_user_updated_by")
  autoGenerateUpdated			auto_number[]		@relation("reference_auto_number_user_updated_by")
  activityCreated			activity[]		@relation("reference_activity_user_created_by")
  activityUpdated			activity[]		@relation("reference_activity_user_updated_by")
  CreatedApiUsers			api_user[]		@relation("reference_api_user_created_by")
  UpdatedApiUsers			api_user[]		@relation("reference_api_user_updated_by")
  UpdatedEndpoints			endpoint[]		@relation("reference_endpoint_updated_by")
  CreatedEndpoints			endpoint[]		@relation("reference_endpoint_created_by")
  processesCreated			process[]		@relation("reference_process_user_created_by")
  processesUpdated			process[]		@relation("reference_process_user_updated_by")
  flowsCreated			flow_defination[]		@relation("reference_flow_defination_user_created_by")
  flowsUpdated			flow_defination[]		@relation("reference_flow_defination_user_updated_by")
  waitingProcessesCreated			waiting_process[]		@relation("reference_waiting_process_user_created_by")
  waitingProcessesUpdated			waiting_process[]		@relation("reference_waiting_process_user_updated_by")
  UIComponentsCreated			ui_component[]		@relation("reference_ui_component_created_by")
  UIComponentsUpdated			ui_component[]		@relation("reference_ui_component_updated_by")
  navigationCreated			system_nav[]		@relation("reference_system_nav_user_created_by")
  navigationUpdated			system_nav[]		@relation("reference_system_nav_user_updated_by")
  inventoryCreated			inventory_item[]		@relation("reference_inventory_created_by")
  inventoryUpdated			inventory_item[]		@relation("reference_inventory_updated_by")
  deliveryCreated			delivery[]		@relation("reference_delivery_created_by")
  deliveryUpdated			delivery[]		@relation("reference_delivery_updated_by")
  productCreated			product[]		@relation("reference_product_user_created_by")
  productUpdated			product[]		@relation("reference_product_user_updated_by")
  customerCreated			customer[]		@relation("reference_customer_user_created_by")
  customerUpdated			customer[]		@relation("reference_customer_user_updated_by")
  manageStores			store[]		@relation("reference_store_user_managed_by")
  storeCreated			store[]		@relation("reference_store_user_created_by")
  storeUpdated			store[]		@relation("reference_store_user_updated_by")
  storeItemCreated			store_item[]		@relation("reference_store_item_user_created_by")
  storeItemUpdated			store_item[]		@relation("reference_store_item_user_updated_by")
  storeProductCreated			store_product[]		@relation("reference_product_store_product_user_created_by")
  storeProductUpdated			store_product[]		@relation("reference_product_store_product_user_updated_by")
  approvedPurchases			purchase[]		@relation("reference_purchase_approved_by")
  purchaseCreated			purchase[]		@relation("reference_purchase_user_created_by")
  purchaseUpdated			purchase[]		@relation("reference_purchase_user_updated_by")
  purchaseItemCreated			purchase_item[]		@relation("reference_purchase_item_user_created_by")
  purchaseItemUpdated			purchase_item[]		@relation("reference_purchase_item_user_updated_by")
  serviceCreated			service[]		@relation("reference_service_created_by")
  serviceUpdated			service[]		@relation("reference_service_updated_by")
  managedProductions			production[]		@relation("reference_production_managed_by")
  productionsCreated			production[]		@relation("reference_production_user_created_by")
  productionsUpdated			production[]		@relation("reference_production_user_updated_by")
  autoGenerateCreated			auto_number[]		@relation("reference_auto_number_user_created_by")
  consumptionCreated			production_consumption[]		@relation("reference_production_consumption_user_created_by")
  consumptionUpdated			production_consumption[]		@relation("reference_production_consumption_user_updated_by")
  finishedProductCreated			finished_product[]		@relation("reference_finished_product_user_created_by")
  finishedProductUpdated			finished_product[]		@relation("reference_finished_product_user_updated_by")
  Sells			sell[]		@relation("reference_sell_sold_by")
  sellsCreated			sell[]		@relation("reference_sell_user_created_by")
  sellsUpdated			sell[]		@relation("reference_sell_user_updated_by")
  sellCreated			sell_product[]		@relation("reference_sell_product_user_created_by")
  sellUpdated			sell_product[]		@relation("reference_sell_product_user_updated_by")
  accountsCreated			account[]		@relation("reference_account_user_created_by")
  accountsUpdated			account[]		@relation("reference_account_user_updated_by")
  transactionsCreated			transaction[]		@relation("reference_transaction_user_created_by")
  transactionsUpdated			transaction[]		@relation("reference_transaction_user_updated_by")
  WorksIn			user_store[]		@relation("reference_user_works_in_store")
  userStoreCreated			user_store[]		@relation("reference_userStore_user_created_by")
  userStoreUpdated			user_store[]		@relation("reference_userStore_user_updated_by")
  transfersCreated			transfer[]		@relation("reference_transfer_user_created_by")
  transfersUpdated			transfer[]		@relation("reference_transfer_user_updated_by")
  transferProdctusCreated			transfer_product[]		@relation("reference_transfer_product_user_created_by")
  transferProductsUpdated			transfer_product[]		@relation("reference_transfer_product_user_updated_by")
  productReceived			receive_product[]		@relation("reference_receive_product_has_receiver")
  productReceivedCreater			receive_product[]		@relation("reference_receive_product_has_created_by")
  productReceivedUpdater			receive_product[]		@relation("reference_receive_product_has_updated_by")
  issuePoster			issue_ticket[]		@relation("reference_issue_user_created_by")
  issueUpdater			issue_ticket[]		@relation("reference_issue_user_updated_by")
  approvedTransfers			transfer[]		@relation("reference_transfer_user_approved_by")
  acceptedTransfers			transfer[]		@relation("reference_user_transfer_accepted_by")
  StationCreated			station[]		@relation("reference_charger_station_user_created_by")
  StationUpdated			station[]		@relation("reference_charger_station_user_updated_by")
  PaymentRateCreated			payment_rate[]		@relation("reference_charger_payment_rate_user_created_by")
  PaymentRateUpdated			payment_rate[]		@relation("reference_charger_payment_rate_user_updated_by")
  RateRangeCreated			rate_range[]		@relation("reference_rate_range_user_created_by")
  RateRangeUpdated			rate_range[]		@relation("reference_rate_range_user_updated_by")
  chargerConnectorCreated			charger_connector[]		@relation("reference_charger_connector_user_created_by")
  chargerConnectorUpdated			charger_connector[]		@relation("reference_charger_connector_user_updated_by")
  chargerAccessCardUser			charger_access_card[]		@relation("reference_charger_access_card_user_user_id")
  chargerAccessCardCreated			charger_access_card[]		@relation("reference_charger_access_card_user_created_by")
  chargerAccessCardUpdated			charger_access_card[]		@relation("reference_charger_access_card_user_updated_by")
  chargedUser			charger_trx[]		@relation("reference_charger_trx_user_user_id")
  chargerTrxCreated			charger_trx[]		@relation("reference_charger_trx_user_created_by")
  chargerTrxUpdated			charger_trx[]		@relation("reference_charger_trx_user_updated_by")
  MainTrxCreated			main_transaction[]		@relation("reference_main_trx_user_created_by")
  MainTrxUpdater			main_transaction[]		@relation("reference_main_trx_user_updated_by")
  postsCreated			post[]		@relation("reference_post_user_created_by")
  postsUpdated			post[]		@relation("reference_post_user_updated_by")
  creater			user?		@relation("reference_user_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_user_user_updated_by", fields: [updated_by], references: [sys_id])
}

model userRole {
  sys_id			String		@id @default(uuid())
  role			String		 @db.VarChar(30)
  user_id			String		 @db.VarChar(36)
  active			Boolean		
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  user			user		@relation("reference_user_roles", fields: [user_id], references: [sys_id])
  creater			user?		@relation("reference_userRole_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_userRole_user_updated_by", fields: [updated_by], references: [sys_id])
}

model choice {
  sys_id			String		@id @default(uuid())
  label			String		 @db.VarChar(50)
  id			String		 @db.VarChar(50)
  value			String		 @db.VarChar(50)
  color			String?		
  bgColor			String?		
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  creater			user?		@relation("reference_choice_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_choice_user_updated_by", fields: [updated_by], references: [sys_id])
}

model inventory_item {
  sys_id			String		@id @default(uuid())
  name			String		 @db.VarChar(100)
  item_number			String		 @db.VarChar(50)
  type			String		 @db.VarChar(20)
  measuring_unit			String		 @db.VarChar(20)
  unit_price			Float		 @db.Float
  is_defination			Boolean?		
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  storeInventories			store_item[]		@relation("reference_store_item_inventory_item_in_store")
  purchaseItem			purchase_item[]		@relation("reference_purchased_item_has_inventory_item")
  itemConsumed			production_consumption[]		@relation("reference_production_consumption_has_inventory_item")
  creater			user?		@relation("reference_inventory_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_inventory_updated_by", fields: [updated_by], references: [sys_id])
}

model delivery {
  sys_id			String		@id @default(uuid())
  name			String		 @db.VarChar(50)
  phone_number			String		@unique @db.VarChar(14)
  vehicle_type			String		 @db.VarChar(20)
  vehicle_number			String		 @db.VarChar(20)
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  deliveredSells			sell[]		@relation("reference_sell_delivery")
  deliveredTransfers			transfer[]		@relation("reference_transfer_delivery")
  creater			user?		@relation("reference_delivery_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_delivery_updated_by", fields: [updated_by], references: [sys_id])
}

model attachment {
  sys_id			String		@id @default(uuid())
  name			String		 @db.VarChar(100)
  table			String		 @db.VarChar(50)
  record			String?		 @db.VarChar(38)
  file_name			String?		 @db.VarChar(100)
  extension			String?		 @db.VarChar(50)
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  Documents			attachment_document[]		@relation("reference_attachmentDocument_attachment_attachment_id")
  creater			user?		@relation("reference_attachment_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_attachment_user_updated_by", fields: [updated_by], references: [sys_id])
}

model attachment_document {
  sys_id			String		@id @default(uuid())
  content			String		 @db.LongText
  created_on			DateTime?		
  attachment_id			String		 @db.VarChar(36)
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  Attachment			attachment		@relation("reference_attachmentDocument_attachment_attachment_id", fields: [attachment_id], references: [sys_id])
  creater			user?		@relation("reference_attachmentDocument_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_attachmentDocument_user_updated_by", fields: [updated_by], references: [sys_id])
}

model product {
  sys_id			String		@id @default(uuid())
  name			String		 @db.VarChar(50)
  product_number			String		@unique @db.VarChar(50)
  measuring_unit			String		 @db.VarChar(20)
  unit_price			Float		 @db.Float
  minimum_level			Int		
  active			Boolean		
  description			String?		 @db.LongText
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  ProductStoreItems			store_product[]		@relation("reference_product_has_many_product_item")
  finishedProducts			finished_product[]		@relation("reference_finished_product_has_product")
  sellProducts			sell_product[]		@relation("reference_sell_product_has_product")
  transferItems			transfer_product[]		@relation("reference_transfer_product_has_product")
  creater			user?		@relation("reference_product_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_product_user_updated_by", fields: [updated_by], references: [sys_id])
}

model customer {
  sys_id			String		@id @default(uuid())
  name			String		 @db.VarChar(50)
  phone_number			String		@unique @db.VarChar(50)
  address			String		 @db.VarChar(100)
  type			String?		 @db.VarChar(10)
  credite_amount			Int?		
  debt_amount			Int?		
  verified			Boolean?		
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  sellContracts			purchase[]		@relation("reference_purchase_customer")
  servicesProvided			service[]		@relation("reference_service_provider")
  buyContracts			sell[]		@relation("reference_sell_customer")
  creater			user?		@relation("reference_customer_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_customer_user_updated_by", fields: [updated_by], references: [sys_id])
}

model store {
  sys_id			String		@id @default(uuid())
  name			String		 @db.VarChar(50)
  location			String		 @db.VarChar(100)
  longitude			String?		 @db.VarChar(100)
  latitude			String?		 @db.VarChar(100)
  legacy_id			Int?		
  manager			String		 @db.VarChar(36)
  active			Boolean		
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  storeItems			store_item[]		@relation("reference_store_has_store_item")
  storeProducts			store_product[]		@relation("reference_product_item_has_one_store")
  storePurchases			purchase[]		@relation("reference_store_has_purchase")
  storePurchaseItems			purchase_item[]		@relation("reference_store_has_purchase_item")
  Productions			production[]		@relation("reference_store_has_production")
  storeConsumption			production_consumption[]		@relation("reference_store_has_production_consumption")
  finishedProducts			finished_product[]		@relation("reference_store_has_finished_product")
  storeSells			sell[]		@relation("reference_store_has_sell")
  storeSellProduct			sell_product[]		@relation("reference_store_has_sell_product")
  workers			user_store[]		@relation("reference_store_has_worker")
  fromStores			transfer[]		@relation("transfer_has_from_store")
  toStores			transfer[]		@relation("transfer_has_to_store")
  receveSlips			receive_product[]		@relation("reference_store_has_receive_products")
  Chargers			station[]		@relation("reference_charger_station_branch_id")
  ConnectorPorts			charger_connector[]		@relation("reference_charger_connector_branch_branch_id")
  chargerTrxes			charger_trx[]		@relation("reference_charger_trx_store_branch_id")
  managedBy			user		@relation("reference_store_user_managed_by", fields: [manager], references: [sys_id])
  creater			user?		@relation("reference_store_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_store_user_updated_by", fields: [updated_by], references: [sys_id])
}

model store_item {
  sys_id			String		@id @default(uuid())
  item_id			String		 @db.VarChar(36)
  quantity			Float		 @db.Float
  total_price			Float?		 @db.Float
  level_state			String		 @db.VarChar(20)
  store_id			String		 @db.VarChar(36)
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  inStore			store		@relation("reference_store_has_store_item", fields: [store_id], references: [sys_id])
  inventoryItem			inventory_item		@relation("reference_store_item_inventory_item_in_store", fields: [item_id], references: [sys_id])
  creater			user?		@relation("reference_store_item_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_store_item_user_updated_by", fields: [updated_by], references: [sys_id])
}

model store_product {
  sys_id			String		@id @default(uuid())
  product_id			String		 @db.VarChar(36)
  quantity			Float		 @db.Float
  total_price			Float?		 @db.Float
  level_state			String		 @db.VarChar(20)
  store_id			String		 @db.VarChar(36)
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  ProductStore			store		@relation("reference_product_item_has_one_store", fields: [store_id], references: [sys_id])
  ItemProduct			product		@relation("reference_product_has_many_product_item", fields: [product_id], references: [sys_id])
  creater			user?		@relation("reference_product_store_product_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_product_store_product_user_updated_by", fields: [updated_by], references: [sys_id])
}

model purchase {
  sys_id			String		@id @default(uuid())
  purchase_number			String?		@unique @db.VarChar(40)
  store_id			String		 @db.VarChar(36)
  customer_id			String		 @db.VarChar(36)
  status			String?		 @db.VarChar(20)
  approved_by			String?		 @db.VarChar(36)
  total_price			Float?		 @db.Float
  paid_amount			Float?		 @db.Float
  remained_amount			Float?		 @db.Float
  tax_amount			Float?		 @db.Float
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  purchaseItems			purchase_item[]		@relation("reference_purchased_has_purchase_item")
  transactions			transaction[]		@relation("reference_purchase_transaction")
  purchaseStore			store		@relation("reference_store_has_purchase", fields: [store_id], references: [sys_id])
  ApprovedBy			user?		@relation("reference_purchase_approved_by", fields: [approved_by], references: [sys_id])
  boughtFrom			customer		@relation("reference_purchase_customer", fields: [customer_id], references: [sys_id])
  creater			user?		@relation("reference_purchase_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_purchase_user_updated_by", fields: [updated_by], references: [sys_id])
}

model purchase_item {
  sys_id			String		@id @default(uuid())
  item_id			String		 @db.VarChar(36)
  store_id			String		 @db.VarChar(36)
  purchase_id			String		 @db.VarChar(36)
  quantity			Float		 @db.Float
  unit_price			Float		 @db.Float
  tax_percentage			Float?		 @db.Float
  before_tax			Float?		 @db.Float
  tax_amount			Float?		 @db.Float
  total_price			Float?		 @db.Float
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  purchaseItemStore			store		@relation("reference_store_has_purchase_item", fields: [store_id], references: [sys_id])
  Purchase			purchase		@relation("reference_purchased_has_purchase_item", fields: [purchase_id], references: [sys_id])
  purchaseItem			inventory_item		@relation("reference_purchased_item_has_inventory_item", fields: [item_id], references: [sys_id])
  creater			user?		@relation("reference_purchase_item_user_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_purchase_item_user_updated_by", fields: [updated_by], references: [sys_id])
}

model service {
  sys_id			String		@id @default(uuid())
  name			String		 @db.VarChar(50)
  customer_id			String		 @db.VarChar(36)
  type			String		 @db.VarChar(20)
  interval_type			String		 @db.VarChar(20)
  price			Float		 @db.Float
  last_payment_date			DateTime		
  next_payment_date			DateTime?		
  created_on			DateTime?		
  updated_on			DateTime?		
  created_by			String?		 @db.VarChar(36)
  updated_by			String?		 @db.VarChar(36)


  transactions			transaction[]		@relation("reference_service_transaction")
  Provider			customer		@relation("reference_service_provider", fields: [customer_id], references: [sys_id])
  creater			user?		@relation("reference_service_created_by", fields: [created_by], references: [sys_id])
  updater			user?		@relation("reference_service_updated_by", fields: [updated_by], references: [sys_id])
}

model production {
